{
  "name": "tb-step-by-step",
  "version": "1.0.0",
  "description": "Fixed-step, file-driven, human-controlled bidding document workflow tool",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "prestart": "npm run build",
    "config": "node dist/commands/config.js",
    "preconfig": "npm run build",
    "test:model": "node dist/commands/test-model.js",
    "pretest:model": "npm run build",
    "test:sections": "node dist/commands/test-sections.js",
    "pretest:sections": "npm run build",
    "step1": "node dist/commands/step1.js",
    "prestep1": "npm run build",
    "step2:outline": "node dist/commands/step2-outline.js",
    "prestep2:outline": "npm run build",
    "step2:confirm": "node dist/commands/step2-confirm.js",
    "prestep2:confirm": "npm run build",
    "step2:section": "node dist/commands/step2-section.js",
    "prestep2:section": "npm run build",
    "step2:status": "node dist/commands/step2-status.js",
    "prestep2:status": "npm run build",
    "final:combine": "node dist/commands/final-combine.js",
    "prefinal:combine": "npm run build",
    "workflow": "node dist/commands/workflow.js",
    "preworkflow": "npm run build",
    "web": "node dist/web/server.js",
    "preweb": "npm run test:web-js && npm run build",
    "test:web-js": "node --check src/web/public/app.js && node --check src/web/public/ui-text.js",
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist"
  },
  "keywords": [
    "bidding",
    "workflow",
    "llm",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "docx": "^9.7.1",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "inquirer": "^8.2.6",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/inquirer": "^8.2.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0"
  }
}
